{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(curl *)"
    ],
    "ask": [
      "Bash(gh *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(rm *)"
    ]
  }
}
